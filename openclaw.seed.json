{
  "meta": {
    "lastTouchedVersion": "2026.3.13",
    "lastTouchedAt": "2026-03-19T00:00:00.000Z"
  },
  "env": {
    "GATEKEEPER_INTERNAL_TOKEN": "${GATEKEEPER_INTERNAL_TOKEN}"
  },
  "auth": {
    "profiles": {
      "openai:default": {
        "provider": "openai",
        "mode": "api_key"
      },
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "api_key"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "gk-aimee": {
        "baseUrl": "http://gatekeeper:9090/llm/openai/agents/primary",
        "apiKey": "${GATEKEEPER_INTERNAL_TOKEN}",
        "api": "openai-completions",
        "models": [
          {
            "id": "gpt-5.4",
            "name": "GPT-5.4 via Gatekeeper (Aimee)",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 16384
          }
        ]
      },
      "gk-cto": {
        "baseUrl": "http://gatekeeper:9090/llm/anthropic/agents/cto",
        "apiKey": "${GATEKEEPER_INTERNAL_TOKEN}",
        "api": "anthropic-messages",
        "models": [
          {
            "id": "claude-sonnet-4-6",
            "name": "Claude Sonnet 4.6 via Gatekeeper (CTO)",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 8192
          },
          {
            "id": "claude-opus-4-6",
            "name": "Claude Opus 4.6 via Gatekeeper (CTO fallback)",
            "reasoning": true,
            "input": ["text", "image"],
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      },
      "gk-jr": {
        "baseUrl": "http://gatekeeper:9090/llm/openai/agents/jr",
        "apiKey": "${GATEKEEPER_INTERNAL_TOKEN}",
        "api": "openai-completions",
        "models": [
          {
            "id": "gpt-4o-mini",
            "name": "GPT-4o Mini via Gatekeeper (Jr)",
            "reasoning": false,
            "input": ["text", "image"],
            "contextWindow": 128000,
            "maxTokens": 16384
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "gk-jr/gpt-4o-mini",
        "fallbacks": []
      },
      "workspace": "/home/node/.openclaw/workspace",
      "contextTokens": 128000
    },
    "list": [
      {
        "id": "primary",
        "name": "Aimee",
        "workspace": "/home/node/.openclaw/agents/primary",
        "agentDir": "/home/node/.openclaw/agents/primary",
        "model": {
          "primary": "gk-aimee/gpt-5.4",
          "fallbacks": []
        },
        "tools": {
          "allow": [
            "lobster",
            "sessions_send",
            "sessions_list",
            "memory_search",
            "memory_get",
            "web_search",
            "web_fetch",
            "read",
            "write",
            "edit",
            "exec"
          ],
          "fs": { "workspaceOnly": true }
        }
      },
      {
        "id": "cto",
        "name": "CTO",
        "workspace": "/home/node/.openclaw/agents/cto",
        "agentDir": "/home/node/.openclaw/agents/cto",
        "model": {
          "primary": "gk-cto/claude-sonnet-4-6",
          "fallbacks": [
            "gk-cto/claude-opus-4-6"
          ]
        },
        "tools": {
          "allow": [
            "lobster",
            "sessions_send",
            "sessions_list",
            "memory_search",
            "memory_get",
            "web_search",
            "web_fetch",
            "read",
            "write",
            "edit",
            "exec"
          ],
          "fs": { "workspaceOnly": true }
        }
      },
      {
        "id": "jr",
        "name": "Jr",
        "workspace": "/home/node/.openclaw/agents/jr",
        "agentDir": "/home/node/.openclaw/agents/jr",
        "model": {
          "primary": "gk-jr/gpt-4o-mini",
          "fallbacks": []
        },
        "tools": {
          "allow": [
            "lobster",
            "sessions_send",
            "sessions_list",
            "memory_search",
            "memory_get",
            "web_fetch",
            "read",
            "write"
          ],
          "fs": { "workspaceOnly": true }
        }
      }
    ]
  },
  "tools": {
    "profile": "coding",
    "sessions": {
      "visibility": "all"
    },
    "agentToAgent": {
      "enabled": true
    },
    "exec": {
      "security": "allowlist",
      "ask": "on-miss"
    },
    "fs": {
      "workspaceOnly": true
    }
  },
  "bindings": [],
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true
  },
  "session": {
    "dmScope": "per-channel-peer",
    "maintenance": {
      "mode": "enforce",
      "pruneAfter": "3d",
      "maxEntries": 100
    }
  },
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": { "enabled": true },
        "session-memory": { "enabled": true }
      }
    }
  },
  "channels": {
    "slack": {
      "enabled": false,
      "mode": "socket",
      "accounts": {},
      "defaultAccount": ""
    },
    "msteams": {
      "enabled": false
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "bind": "lan",
    "auth": {
      "mode": "token",
      "token": "${OPENCLAW_AUTH_TOKEN}"
    }
  },
  "memory": {
    "backend": "qmd",
    "citations": "auto",
    "qmd": {
      "searchMode": "search",
      "includeDefaultMemory": true,
      "paths": [
        {
          "path": "/home/node/.openclaw/sops",
          "name": "corporate-sops",
          "pattern": "**/*.md"
        },
        {
          "path": "/home/node/.openclaw/lobster",
          "name": "workflows",
          "pattern": "**/*.lobster"
        }
      ],
      "update": {
        "interval": "5m",
        "debounceMs": 2000
      }
    }
  },
  "plugins": {
    "entries": {
      "lobster": {
        "enabled": true
      }
    }
  }
}
