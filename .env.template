# CTG Core — Environment Configuration
# Copy to .env and fill in values: cp .env.template .env
# Generated by setup.sh on first run

# ============================================================
# PostgreSQL (internal — not exposed to host)
# ============================================================
PG_USER=ctgcore
PG_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL
PG_DB=ctgcore

# ============================================================
# Gatekeeper (LLM proxy + content sanitizer + usage ledger)
# ============================================================
# API keys — these are injected by Gatekeeper into outbound LLM requests.
# Agents never see these keys directly.
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENAI_API_KEY=

# Internal auth token — all services must include this when calling Gatekeeper
GATEKEEPER_INTERNAL_TOKEN=CHANGE_ME_GENERATE_WITH_OPENSSL

# Gatekeeper config
GATEKEEPER_PORT=9090
GATEKEEPER_DB_PATH=/data/gatekeeper.db
GATEKEEPER_PRICING_PATH=/data/pricing.json
GATEKEEPER_DOMAIN_ALLOWLIST=*

# License enforcement — hours before graceful degradation if hub unreachable
LICENSE_GRACE_HOURS=72

# ============================================================
# Port Mappings (offset +10000 from container ports)
# ============================================================
PAPERCLIP_PORT=13100
MC_PORT=14000
GW_PORT=28789
GATEKEEPER_HOST_PORT=19090
N8N_PORT=5678

# ============================================================
# OpenClaw Gateway
# ============================================================
# Auth token for gateway API access (auto-generated by setup.sh)
OPENCLAW_AUTH_TOKEN=CHANGE_ME_GENERATE_WITH_OPENSSL

# ============================================================
# Paperclip
# ============================================================
PAPERCLIP_API_KEY=
DEPLOYMENT_MODE=local_trusted

# ============================================================
# n8n (Credential Isolation)
# ============================================================
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL
N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL

# ============================================================
# Tenant Identity
# ============================================================
# Unique company ID (UUID, auto-generated by setup.sh)
COMPANY_ID=CHANGE_ME_UUID

# ============================================================
# Parent Hub (Remote Management)
# ============================================================
# URL of the CTG parent hub for remote management
PARENT_HUB_URL=https://hub.cubillastech.com

# Management token (provided by CTG during onboarding)
PARENT_HUB_TOKEN=CHANGE_ME_PROVIDED_BY_CTG

# Health check-in interval in milliseconds (default: 5 minutes)
CHECKIN_INTERVAL_MS=300000
